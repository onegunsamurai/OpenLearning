# Fallback Anthropic API key (optional — users provide their own via BYOK)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# SQLAlchemy async database URL (default: PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://openlearning:openlearning@localhost:5432/openlearning

# LangSmith tracing (optional)
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=open-learning
# LANGSMITH_TRACING=false

# GitHub OAuth (required for authentication)
# GITHUB_CLIENT_ID=your_github_oauth_app_client_id
# GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# JWT signing key (required for authentication — use a random 256-bit hex string)
# JWT_SECRET_KEY=your_random_secret_key_here

# Fernet encryption key for API key storage (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# ENCRYPTION_KEY=your_fernet_key_here

# Frontend URL for OAuth redirect
# FRONTEND_URL=http://localhost:3000

# GITHUB_CLIENT_ID=*
# GITHUB_CLIENT_SECRET=
# JWT_SECRET_KEY=
# ENCRYPTION_KEY=
# FRONTEND_URL=http://localhost:3000
